# ── Cloudflare Radar ─────────────────────────────────────────────────────────
# Requerido. Token con permiso Radar:Read.
# Obtenerlo en: https://dash.cloudflare.com/profile/api-tokens
CF_TOKEN=

# ── Riot API ──────────────────────────────────────────────────────────────────
# Opcional. Solo necesario si quieres poblar la tabla riot_status.
# Usar la key de producto aprobado (no la Development Key, que expira cada 24h).
RIOT_TOKEN=

# ── PostgreSQL / PostGIS ──────────────────────────────────────────────────────
# Usadas por docker-compose para inicializar el contenedor y por los servicios
# para conectarse. Cambiar en producción.
POSTGRES_USER=mageuser
POSTGRES_PASSWORD=magepass
POSTGRES_DB=magedb
