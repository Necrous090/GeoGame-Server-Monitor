# ── Cloudflare Radar ────────────────────────────────────────────────
# Token con permiso Radar:Read
CF_TOKEN=

# ── Riot API ────────────────────────────────────────────────────────
# Key del producto aprobado (GEOGAME SERVER MONITOR), NO la Development
# Key del dashboard, que expira cada 24h.
RIOT_TOKEN=

# ── PostgreSQL / PostGIS ────────────────────────────────────────────
# Las usa docker-compose para inicializar el contenedor.
POSTGRES_USER=mageuser
POSTGRES_PASSWORD=magepass
POSTGRES_DB=magedb
